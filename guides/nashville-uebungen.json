  "sections": [
    {
      "title": { "de": "Spickzettel", "en": "Cheat sheet" },
      "blocks": [
        {
          "type": "note",
          "text": {
            "de": "Stufen-Klang in jeder Tonart gleich: 1 Dur · 2 Moll · 3 Moll · 4 Dur · 5 Dur · 6 Moll · 7 Sonderfall (5/7). Die erste Zeile jeder Übung ist als Beispiel ausgefüllt.",
            "en": "Number quality is the same in every key: 1 maj · 2 min · 3 min · 4 maj · 5 maj · 6 min · 7 special case (5/7). The first row of each exercise is filled in as an example."
          }
        }
      ]
    },
