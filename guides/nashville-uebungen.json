    {
      "title": { "de": "8 · richtig oder falsch?", "en": "8 · True or false?" },
      "intro": { "de": "Stimmt die Aussage? Bei „falsch“ steht die richtige Antwort in der Lösung.", "en": "Is the statement correct? For “false” the right answer is in the solution." },
      "blocks": [
        {
          "type": "bullets",
          "items": [
            { "de": "In C-Dur ist die 6 = Am.", "en": "In C major the 6 = Am." },
            { "de": "In G-Dur ist die 4 = D.", "en": "In G major the 4 = D." },
            { "de": "Die 5 klingt immer Moll.", "en": "The 5 always sounds minor." },
            { "de": "In D-Dur ist die 2 = Em.", "en": "In D major the 2 = Em." },
            { "de": "In A-Dur ist die 3 = C#m.", "en": "In A major the 3 = C#m." },
            { "de": "Die 4 ist die Dominante.", "en": "The 4 is the dominant." },
            { "de": "In F-Dur ist die 6 = Dm.", "en": "In F major the 6 = Dm." },
            { "de": "In E-Dur ist die 5 = B.", "en": "In E major the 5 = B." }
          ]
        },
        {
          "type": "solution", "label": { "de": "Lösungen anzeigen", "en": "Show solutions" },
          "blocks": [{
            "type": "table",
            "head": [ {"de":"Aussage","en":"Statement"},{"de":"richtig / falsch","en":"true / false"},{"de":"richtig ist…","en":"correct is…"} ],
            "rows": [
              [ {"de":"6 = Am (C-Dur)","en":"6 = Am (C major)"},{"de":"richtig","en":"true"},{"de":"–","en":"–"} ],
              [ {"de":"4 = D (G-Dur)","en":"4 = D (G major)"},{"de":"falsch","en":"false"},{"de":"4 = C (D ist die 5)","en":"4 = C (D is the 5)"} ],
              [ {"de":"Die 5 ist Moll","en":"The 5 is minor"},{"de":"falsch","en":"false"},{"de":"die 5 ist immer Dur","en":"the 5 is always major"} ],
              [ {"de":"2 = Em (D-Dur)","en":"2 = Em (D major)"},{"de":"richtig","en":"true"},{"de":"–","en":"–"} ],
              [ {"de":"3 = C#m (A-Dur)","en":"3 = C#m (A major)"},{"de":"richtig","en":"true"},{"de":"–","en":"–"} ],
              [ {"de":"Die 4 ist die Dominante","en":"The 4 is the dominant"},{"de":"falsch","en":"false"},{"de":"die 4 ist die Subdominante","en":"the 4 is the subdominant"} ],
              [ {"de":"6 = Dm (F-Dur)","en":"6 = Dm (F major)"},{"de":"richtig","en":"true"},{"de":"–","en":"–"} ],
              [ {"de":"5 = B (E-Dur)","en":"5 = B (E major)"},{"de":"richtig","en":"true"},{"de":"–","en":"–"} ]
            ]
          }]
        }
