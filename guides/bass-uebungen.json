              [ {"de":"Tief und offen, ohne Terz","en":"Low and open, no third"},{"de":"Shell","en":"Shell"} ],
              [ {"de":"Mittig, warm und komplett","en":"Mid, warm and complete"},{"de":"Voll","en":"Full"} ],
              [ {"de":"Ganz unten, soll nicht matschen","en":"Right at the bottom, must not get muddy"},{"de":"Grundton","en":"Root"} ],
              [ {"de":"Höhere Lage, voller Klang erlaubt","en":"Higher register, full sound allowed"},{"de":"Voll","en":"Full"} ]
            ]
          }]
        }
      ]
