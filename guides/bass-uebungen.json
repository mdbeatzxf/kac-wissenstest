    {
      "title": { "de": "Übung 6: Richtig oder falsch?", "en": "Exercise 6: true or false?" },
      "intro": { "de": "Stimmt die Aussage? Bei „falsch“ steht die richtige Antwort in der Lösung.", "en": "Is the statement correct? For “false” the right answer is in the solution." },
      "blocks": [
        {
          "type": "bullets",
          "items": [
            { "de": "Beim vollen Voicing spielst du die Terz eine Oktave höher.", "en": "In the full voicing you play the third an octave higher." },
            { "de": "Ganz tief klingt ein voller Dreiklang am besten.", "en": "A full triad sounds best right down low." },
            { "de": "Shell heißt Grundton + Quinte, ohne Terz.", "en": "Shell means root + fifth, without the third." },
            { "de": "Bei Moll wird auch die Quinte einen Halbton kleiner.", "en": "In minor the fifth also drops a semitone." },
            { "de": "In der 1. Umkehrung liegt die Terz im Bass.", "en": "In the 1st inversion the third is in the bass." },
            { "de": "Eine Umkehrung ändert, welche Töne im Akkord sind.", "en": "An inversion changes which notes are in the chord." },
            { "de": "Grundton, Oktave und Shell klingen in Dur und Moll gleich.", "en": "Root, octave and shell sound the same in major and minor." }
          ]
        },
        {
          "type": "solution", "label": { "de": "Lösungen anzeigen", "en": "Show solutions" },
          "blocks": [{
            "type": "table",
            "head": [ {"de":"Aussage","en":"Statement"},{"de":"richtig / falsch","en":"true / false"},{"de":"richtig ist…","en":"correct is…"} ],
            "rows": [
              [ {"de":"Terz im vollen Voicing eine Oktave höher","en":"Third in the full voicing an octave higher"},{"de":"richtig","en":"true"},{"de":"–","en":"–"} ],
              [ {"de":"Voller Dreiklang ganz tief am besten","en":"Full triad best very low"},{"de":"falsch","en":"false"},{"de":"tief lieber Grundton oder Shell — voll wird matschig","en":"low → rather root or shell — full gets muddy"} ],
              [ {"de":"Shell = Grundton + Quinte, ohne Terz","en":"Shell = root + fifth, no third"},{"de":"richtig","en":"true"},{"de":"–","en":"–"} ],
              [ {"de":"Bei Moll wird die Quinte kleiner","en":"In minor the fifth gets smaller"},{"de":"falsch","en":"false"},{"de":"nur die Terz wird kleiner (kleine Terz)","en":"only the third gets smaller (minor third)"} ],
              [ {"de":"1. Umkehrung: Terz im Bass","en":"1st inversion: third in bass"},{"de":"richtig","en":"true"},{"de":"–","en":"–"} ],
              [ {"de":"Umkehrung ändert die Töne","en":"Inversion changes the notes"},{"de":"falsch","en":"false"},{"de":"gleiche Töne, anderer Bass / andere Lage","en":"same notes, different bass / position"} ],
              [ {"de":"Grundton/Oktave/Shell: Dur = Moll","en":"Root/octave/shell: major = minor"},{"de":"richtig","en":"true"},{"de":"– (keine Terz enthalten)","en":"– (no third in them)"} ]
            ]
          }]
        }
      ]
